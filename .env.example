# ------------------------------------------------------------------------------
# Django runtime
# ------------------------------------------------------------------------------
CODEFORTIFY_ENVIRONMENT=dev
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
TIME_ZONE=UTC
LANGUAGE_CODE=en-us

# ------------------------------------------------------------------------------
# Database
# Keep DATABASE_URL empty for SQLite fallback outside Docker.
# Docker compose overrides DATABASE_URL to use PostgreSQL automatically.
# ------------------------------------------------------------------------------
DATABASE_URL=
POSTGRES_DB=codefortifyauth
POSTGRES_USER=codefortifyauth
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Redis / Celery
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ------------------------------------------------------------------------------
# URLs / site identity
# ------------------------------------------------------------------------------
SITE_NAME=CodefortifyAuth
SITE_DOMAIN=localhost:8000
APP_BASE_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:8000
BASE_URL=http://127.0.0.1:8000

# ------------------------------------------------------------------------------
# Email
# ------------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@example.com

# ------------------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------------------
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# ------------------------------------------------------------------------------
# Optional security / deployment flags
# ------------------------------------------------------------------------------
CORS_ALLOW_ALL_ORIGINS=True
SECURE_SSL_REDIRECT=False
DB_CONN_MAX_AGE=60
RUN_MIGRATIONS=true
COLLECT_STATIC=false
